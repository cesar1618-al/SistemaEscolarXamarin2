public class Libro
{
    public string Titulo { get; set; }
    public string Autor { get; set; }
    public string Editorial { get; set; }
    public string Genero { get; set; }
    public bool Disponible { get; set; }
}
 <ContentPage xmlns="http://xamarin.com/schemas/2014/forms"
             BackgroundColor="#F4F6F9";
             x:Class="BibliotecaIA.MainPage">

    <StackLayout Padding="20">

        <Label
            Text="Biblioteca Inteligente";
            FontSize="30";
            TextColor="#2C3E5E";
            HorizontalOptions="Center"/>

        <SearchBar
            Placeholder="Buscar libros...";
            TextChanged="BuscarLibro"/>

        <Button
            Text="Agregar Libro";
            BackgroundColor="#3498DB";
            TextColor="White";
            CornerRadius="10"/>

        <Button
            Text="Recomendaciones IA";
            BackgroundColor="#9B59B6";
            TextColor="White";
            CornerRadius="10"/>

        <CollectionView x:Name="listaLibros">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame
                        CornerRadius="15";
                        Margin="5";
                        Padding="10";
                        BackgroundColor="White">

                        <StackLayout>
                            <Label
                                Text="{Binding Titulo}";
                                FontAttributes="Bold";
                                FontSize="18"/>

                            <Label
                                Text="{Binding Autor}";
                                TextColor="Gray"/>

                            <Label
                                Text="{Binding Genero}";
                                TextColor="#2980B9"/>
                        </StackLayout>

                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

    </StackLayout>

</ContentPage>
 using System.Collections.Generic;

public class BibliotecaService
{
    public List<Libro> libros = new List<Libro>();

    public void AgregarLibro(Libro libro)
    {
        libros.Add(libro);
    }

    public List<Libro> ObtenerLibros()
    {
        return libros;
    }
}

<ContentPage xmlns="http://xamarin.com/schemas/2014/forms"
             x:Class="BibliotecaIA.RecomendacionesPage">

    <StackLayout Padding="20">

        <Label
            Text="Recomendaciones Inteligentes";
            FontSize="26"/>

        <Entry
            x:Name="generoFavorito";
            Placeholder="Ingresa tu género favorito"/>

        <Button
            Text="Obtener recomendaciones";
            Clicked="RecomendarLibros"/>

        <CollectionView x:Name="listaRecomendaciones"/>

    </StackLayout>

</ContentPage>
using System.Collections.Generic;
using System.Linq;

public class RecomendadorIA
{
    public List<Libro> Recomendar(string generoFavorito, List<Libro> libros)
    {
        var recomendados = libros
            .Where(l => l.Genero == generoFavorito)
            .ToList();

        return recomendados;
    }
}
